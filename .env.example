# Host ports
AI_HOST_PORT=7788
AI_HOST_EXTERNAL_PORT=7789

# Feishu self-hosted app
FEISHU_APP_ID=cli_xxxxxxxx
FEISHU_APP_SECRET=replace-with-real-secret
FEISHU_VERIFICATION_TOKEN=replace-with-real-token
FEISHU_ENCRYPT_KEY=
FEISHU_SUBSCRIPTION_MODE=long-connection

# Feishu is a CN service. If you have a local proxy via HTTP(S)_PROXY, add
# feishu hostnames here so axios talks to the real endpoint.
NO_PROXY=open.feishu.cn,msg-frontier.feishu.cn,feishu.cn,larksuite.com

# When a Feishu chat with no active binding sends a message, auto-spawn a
# Claude Code session in this workspace and bind the chat to it.
FEISHU_AUTO_SESSION_CWD=
FEISHU_AUTO_SESSION_PERMISSION_MODE=default

# Each Feishu thread (root message + its replies) gets its own Claude Code
# session. Set to "false" to use a single session per chat regardless of thread.
FEISHU_THREAD_ISOLATION=true
